{"atom_id": "md_model01_a007", "file": "knowledge_base/model/01_concepts_and_terms.md", "line_start": 7, "line_end": 7, "parent_section": "§2.1 [Model Concepts and Terms — Variables]", "atom_type": "SENTENCE", "verbatim": "A **domain** is a collection of observations on a particular topic.", "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_md_v1.8", "ts": "2026-04-29T12:00:00Z"}}
