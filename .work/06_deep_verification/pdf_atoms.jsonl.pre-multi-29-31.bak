{"atom_id": "ig34_p0179_a0003", "source": "SDTMIG_v3.4", "page": 179, "page_region": "top", "parent_section": "§6.2.7 Protocol Deviations (DV)", "atom_type": "TABLE_ROW", "verbatim": "| DVSTDY | Study Day of Start of Deviation Event | Num | | Timing | Study day of start of event relative to the sponsor-defined RFSTDTC. | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7_batch18", "ts": "2026-04-25T00:00:00Z"}}
