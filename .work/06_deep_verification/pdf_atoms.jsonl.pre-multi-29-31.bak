{"atom_id": "ig34_p0052_a033", "source": "SDTMIG_v3.4", "page": 52, "page_region": "bottom", "parent_section": "§4.5.1.3 [Examples of Original and Standard Units and Test Not Done]", "atom_type": "SENTENCE", "verbatim": "The following examples are meant to illustrate the use of Findings results variables, and are not meant as comprehensive domain examples.", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch06a_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0052_a034", "source": "SDTMIG_v3.4", "page": 52, "page_region": "bottom", "parent_section": "§4.5.1.3 [Examples of Original and Standard Units and Test Not Done]", "atom_type": "SENTENCE", "verbatim": "Certain required and expected variables are omitted (e.g., USUBJID), and the samples may represent data for more than 1 subject.", "heading_level": null, "sibling_index": 2, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch06a_fix", "ts": "2026-04-25T00:00:00Z"}}
