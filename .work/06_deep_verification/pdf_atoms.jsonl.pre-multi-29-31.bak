{"atom_id": "ig34_p0190_a016", "source": "SDTMIG_v3.4", "page": 190, "page_region": "middle", "parent_section": "§6.3.3 ECG Test Results (EG)", "atom_type": "SENTENCE", "verbatim": "This example shows ECG results where only the overall assessment was collected. Results are for one subject across multiple visits. In addition, the ECG interpretation was provided by the investigator and, when necessary, by a cardiologist. EGGRPID is used to group the overall assessments collected on each ECG.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_OptionE_executor_rerun_NEW3_outer_pipe_explicit_null_key", "ts": "2026-04-25T00:00:00Z"}}
