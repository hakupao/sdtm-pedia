{"atom_id": "ig34_p0012_a001", "source": "SDTMIG_v3.4", "page": 12, "page_region": "top", "parent_section": "§2.2 Datasets and Domains", "atom_type": "SENTENCE", "verbatim": "name, as the value of the DOMAIN variable in that dataset, as a prefix for most variable names in that dataset, and as a value in the RDOMAIN variable in relationship tables (see Section 8, Representing Relationships and Data).", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": ["§8"], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch02_4digit_fix", "ts": "2026-04-24T00:00:00Z"}}
