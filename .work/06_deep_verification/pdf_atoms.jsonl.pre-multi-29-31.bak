{"atom_id": "ig34_p0113_a024", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 113, "atom_index_on_page": 24, "atom_type": "LIST_ITEM", "verbatim": "Bottle C contained placebo (i.e., 0 mg of active ingredient/tablet)", "parent_section": "§6.1.3.3 [Exposure/Exposure as Collected Examples]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": null, "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R14"}
