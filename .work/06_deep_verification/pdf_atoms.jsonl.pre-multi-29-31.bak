{"atom_id":"ig34_p0194_a018","source":"SDTMIG_v3.4","page":194,"page_region":"bottom","parent_section":"§6.3.5 Specimen-based Findings Domains","atom_type":"SENTENCE","verbatim":"Individual domains (e.g., IS, LB, MB) for laboratory measurements, tests, or examinations performed on collected biological specimens (e.g., blood, urine, tumor tissue) are grouped together in this section.","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7","ts":"2026-04-26T00:00:00Z"}}
