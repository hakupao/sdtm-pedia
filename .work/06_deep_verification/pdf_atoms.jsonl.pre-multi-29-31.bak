{"atom_id": "ig34_p0104_a004", "source": "SDTMIG_v3.4", "page": 104, "page_region": "top", "parent_section": "§6.1.3.1 [Exposure (EX)]", "atom_type": "SENTENCE", "verbatim": "Study treatment may be any intervention that is prospectively defined as a test material within a study, and is typically but not always supplied to the subject.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10", "ts": "2026-04-25T00:00:00Z"}}
