{"atom_id": "ig34_p0060_a002", "source": "SDTMIG_v3.4", "page": 60, "page_region": "top", "parent_section": "§5 [Models for Special-purpose Domains]", "atom_type": "SENTENCE", "verbatim": "Special-purpose Domains is an SDTM class in its own right.", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+drift_cal_p60_rerun", "ts": "2026-04-25T00:00:00Z", "role": "drift_cal_rerun_promoted_to_primary"}}
