{"atom_id": "ig34_p0007_a010", "source": "SDTMIG_v3.4", "page": 7, "page_region": "middle", "parent_section": "§1.2 [Organization of this Document]", "atom_type": "SENTENCE", "verbatim": "This document is organized into the following sections:", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2", "ts": "2026-04-24T00:00:00Z"}}
{"atom_id": "ig34_p0007_a011", "source": "SDTMIG_v3.4", "page": 7, "page_region": "middle", "parent_section": "§1.2 [Organization of this Document]", "atom_type": "LIST_ITEM", "verbatim": "Section 1, Introduction, provides an overall introduction to the v3.4 models and describes changes from prior versions.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": ["§1 Introduction"], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2", "ts": "2026-04-24T00:00:00Z"}}
