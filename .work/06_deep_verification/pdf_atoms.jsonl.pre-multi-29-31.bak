{"atom_id": "ig34_p0132_a004", "source": "SDTMIG_v3.4", "page": 132, "page_region": "top", "parent_section": "§6.1.6 [Substance Use (SU)]", "atom_type": "SENTENCE", "verbatim": "This example illustrates how typical SU data could be populated. Here, the CRF collected:", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+R10..R15", "ts": "2026-04-25T00:00:00Z"}}
