{"atom_id": "ig34_p0159_a0026", "source": "SDTMIG_v3.4", "page": 159, "page_region": "bottom", "parent_section": "§6.2.4 Disposition (DS)", "atom_type": "SENTENCE", "verbatim": "The sponsor did not collect disposition of treatment and did not include DSSCAT.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-5", "ts": "2026-04-25T19:00:00Z"}}
