{"atom_id": "ig34_p0034_a022", "source": "SDTMIG_v3.4", "page": 34, "page_region": "bottom", "parent_section": "§4.2.8.2 Multiple Values for a Findings Result Variable", "atom_type": "SENTENCE", "verbatim": "If multiple result values (--ORRES) are reported for a test in a Findings class dataset, multiple records should be submitted for that --TESTCD.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
