{"atom_id": "ig34_p0060_a011", "source": "SDTMIG_v3.4", "page": 60, "page_region": "middle", "parent_section": "§5.1 [Comments (CO)]", "atom_type": "TABLE_ROW", "verbatim": "| STUDYID | Study Identifier | Char | | Identifier | Unique identifier for a study. | Req |", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+drift_cal_p60_rerun", "ts": "2026-04-25T00:00:00Z", "role": "drift_cal_rerun_promoted_to_primary"}}
