{"atom_id": "ig34_p0122_a007", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 122, "atom_index_on_page": 7, "atom_type": "TABLE_ROW", "verbatim": "MLTPT | Planned Time Point Name | Char | | Timing | Name of a planned time point for a measurement or observation should be taken as defined in the protocol. This may be represented as an elapsed time relative to a fixed reference point. | Perm", "parent_section": "§6.1.4 [Meal Data (ML)]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": "ml.xpt", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R15"}
{"atom_id": "ig34_p0122_a008", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 122, "atom_index_on_page": 8, "atom_type": "TABLE_ROW", "verbatim": "MLTPTNUM | Planned Time Point Number | Num | | Timing | Numeric version of planned time point used in sorting. | Perm", "parent_section": "§6.1.4 [Meal Data (ML)]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": "ml.xpt", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R15"}
