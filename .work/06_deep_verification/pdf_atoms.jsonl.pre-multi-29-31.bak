{"atom_id":"ig34_p0202_a027","source":"SDTMIG_v3.4","page":202,"page_region":"bottom","parent_section":"§6.3.5.3 Cell Phenotype Findings (CP)","atom_type":"TABLE_ROW","verbatim":"| CPSTRESC | Result or Finding in Standard Format | Char | | Result Qualifier | Contains the result value for all findings, copied or derived from CPORRES in a standard format or in standard units. CPSTRESC should store all results or findings in character format; if results are numeric, they should also be stored in numeric format in CPSTRESN. | Exp |","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2_inline_R1-R15_NEW1-NEW7_round3_batch21a","ts":"2026-04-26T00:00:00Z"}}
