{"atom_id":"ig34_p0243_a002","source":"SDTMIG_v3.4","page":243,"page_region":"top","parent_section":"§6.3.5.6 Laboratory Test Results (LB)","atom_type":"TABLE_ROW","verbatim":"| LBORNRLO | Reference Range Lower Limit in Orig Unit | Char | | Variable Qualifier | Lower end of reference range for continuous measurement in original units. Should be populated only for continuous results. | Exp |","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2","ts":"2026-04-26T00:00:00Z"}}
