{"atom_id": "ig34_p0040_a007", "source": "SDTMIG_v3.4", "page": 40, "page_region": "top", "parent_section": "§4.4.2 Date/Time Precision", "atom_type": "SENTENCE", "verbatim": "As previously mentioned, ISO 8601 represents missing intermediate components through the use of a hyphen where the missing component would normally be represented.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
