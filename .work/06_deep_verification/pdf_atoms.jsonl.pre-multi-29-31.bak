{"atom_id":"ig34_p0258_a002","source":"SDTMIG_v3.4","page":258,"page_region":"top","parent_section":"§6.3.5.7.3 Microbiology Specimen/Microbiology Susceptibility Examples","atom_type":"LIST_ITEM","verbatim":"Rows 1-3: Show that all 3 samples (IDVARVAL where IDVAR=\"BEREFID\") were sputum, as indicated by QVAL where QNAM=\"BESPEC\" and QLABEL=\"Specimen Type\".","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2","ts":"2026-04-27T00:00:00Z"}}
