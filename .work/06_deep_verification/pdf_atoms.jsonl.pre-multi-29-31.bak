{"atom_id": "ig34_p0229_a008", "source": "SDTMIG_v3.4", "page": 229, "page_region": "top", "parent_section": "§6.3.5.5 Immunogenicity Specimen Assessments (IS)", "atom_type": "TABLE_ROW", "verbatim": "| ISSEQ | Sequence Number | Num | | Identifier | Sequence number to ensure uniqueness of records within a dataset for a subject. May be any valid number (including decimals) and does not have to start at 1. | Req |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+inline-R10-R15+O-P1-26+NEW1-NEW8", "ts": "2026-04-26T00:00:00Z"}}
