{"atom_id": "ig34_p0103_a011", "source": "SDTMIG_v3.4", "page": 103, "page_region": "middle", "parent_section": "§6.1.2 [Concomitant/Prior Medications (CM)]", "atom_type": "LIST_ITEM", "verbatim": "Rows 5-6: Show 2 prior DMARDS received by subject 102, one ending before the date of data collection, and the other ongoing at that time. These medications were not prespecified, so CMPRESP is null.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10+option_E_rerun_p103", "ts": "2026-04-25T00:00:00Z"}}
