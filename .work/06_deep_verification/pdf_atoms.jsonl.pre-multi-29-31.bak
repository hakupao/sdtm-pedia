{"atom_id": "ig34_p0062_a001", "source": "SDTMIG_v3.4", "page": 62, "page_region": "top", "parent_section": "§5.1 [Comments (CO)]", "atom_type": "TABLE_ROW", "verbatim": "Row 6: | Shows one option for representing a comment collected on a visit-specific comments page not associated with a particular domain. In this case, the comment is linked to the Subject Visit record in SV (RDOMAIN = \"SV\") and IDVAR and IDVARVAL are populated link the comment to the particular visit.", "heading_level": null, "sibling_index": 6, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch07a_fix", "ts": "2026-04-25T00:00:00Z"}}
