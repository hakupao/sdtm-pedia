{"atom_id": "ig34_p0122_a010", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 122, "atom_index_on_page": 10, "atom_type": "TABLE_ROW", "verbatim": "MLTPREF | Time Point Reference | Char | ISO 8601 date/time or interval | Timing | Description of the fixed reference time point referred to by MLELTM, MLTPTNUM, and MLTPT. | Perm", "parent_section": "§6.1.4 [Meal Data (ML)]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": "ml.xpt", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R15"}
{"atom_id": "ig34_p0122_a011", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 122, "atom_index_on_page": 11, "atom_type": "TABLE_ROW", "verbatim": "MLRFDTC | Date/Time of Reference | Char | ISO 8601 date/time or interval | Timing | Baseline for a fixed reference time point referred to by MLTPREF in the MLRFDTC. Baseline for a fixed reference time point. | Perm", "parent_section": "§6.1.4 [Meal Data (ML)]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": "ml.xpt", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R15"}
{"atom_id": "ig34_p0122_a012", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 122, "atom_index_on_page": 12, "atom_type": "TABLE_ROW", "verbatim": "MIDS | Disease Milestone Instance Name | Char | | Timing | The name of a specific instance of a disease milestone type (MIDSTYPE) described in the Trial Disease Milestones dataset. This should be unique within a study. Used only in conjunction with RELMIDS and MIDSDTC. | Perm", "parent_section": "§6.1.4 [Meal Data (ML)]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": "ml.xpt", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R15"}
