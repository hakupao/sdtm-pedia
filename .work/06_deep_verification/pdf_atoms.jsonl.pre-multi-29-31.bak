{"atom_id": "ig34_p0105_a007", "source": "SDTMIG_v3.4", "page": 105, "page_region": "top", "parent_section": "§6.1.3.1 [Exposure (EX)]", "atom_type": "TABLE_ROW", "verbatim": "EXENDTC | End Date/Time of Treatment | Char | ISO 8601 datetime or interval | Timing | The datetime when administration of the treatment was considered given at a point in time (e.g., oral tablet, pre-filled syringe injection), where an end date is not available the start date/time should be used for EXSTDTC as the standard representation.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10", "ts": "2026-04-25T00:00:00Z"}}
