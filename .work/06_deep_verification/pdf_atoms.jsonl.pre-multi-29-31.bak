{"atom_id": "ig34_p0146_a006", "source": "SDTMIG_v3.4", "page": 146, "page_region": "upper_middle", "parent_section": "§6.2.2 [Biospecimen Events (BE)]", "atom_type": "SENTENCE", "verbatim": "The Device Identifiers (DI) dataset (required with the use of SPDEVID) is not shown in this example.", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+R15+drift_cal_repair", "ts": "2026-04-25T08:37:25.202985+00:00", "action": "OptionE_p146_wholesale_replace"}}
{"atom_id": "ig34_p0146_a007", "source": "SDTMIG_v3.4", "page": 146, "page_region": "upper_middle", "parent_section": "§6.2.2 [Biospecimen Events (BE)]", "atom_type": "SENTENCE", "verbatim": "RELREC relates the records in BE and BS to each other.", "heading_level": null, "sibling_index": 2, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+R15+drift_cal_repair", "ts": "2026-04-25T08:37:25.202985+00:00", "action": "OptionE_p146_wholesale_replace"}}
