{"atom_id": "ig34_p0007_a013", "source": "SDTMIG_v3.4", "page": 7, "page_region": "middle", "parent_section": "§1.2 [Organization of this Document]", "atom_type": "LIST_ITEM", "verbatim": "Section 3, Submitting Data in Standard Format, explains how to describe metadata for regulatory submissions, and how to assess conformance with the standards.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": ["§3 Submitting Data in Standard Format"], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2", "ts": "2026-04-24T00:00:00Z"}}
