{"atom_id": "ig34_p0061_a016", "source": "SDTMIG_v3.4", "page": 61, "page_region": "middle", "parent_section": "§5.1 [Comments (CO)]", "atom_type": "SENTENCE", "verbatim": "Example 1", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch07a_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0061_a017", "source": "SDTMIG_v3.4", "page": 61, "page_region": "middle", "parent_section": "§5.1 [Comments (CO)]", "atom_type": "TABLE_ROW", "verbatim": "Row 1: | Shows a comment collected on a separate comments page. Since it was unrelated to any specific domain or record, RDOMAIN, IDVAR, and IDVARVAL are null.", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch07a_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0061_a018", "source": "SDTMIG_v3.4", "page": 61, "page_region": "middle", "parent_section": "§5.1 [Comments (CO)]", "atom_type": "TABLE_ROW", "verbatim": "Row 2: | Shows a comment that was collected on the bottom of the PE page for Visit 7, without any indication of specific records it applied to. Since the comment related to a specific domain, RDOMAIN is populated. Since it was related to a specific visit, VISIT, COREF is \"VISIT 7\". However, since it does not relate to a specific record, IDVAR and IDVARVAL are null.", "heading_level": null, "sibling_index": 2, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch07a_fix", "ts": "2026-04-25T00:00:00Z"}}
