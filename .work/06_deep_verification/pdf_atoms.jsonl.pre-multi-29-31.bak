{"atom_id": "ig34_p0227_a002", "source": "SDTMIG_v3.4", "page": 227, "page_region": "top", "parent_section": "§6.3.5.4 Genomics Findings (GF)", "atom_type": "SENTENCE", "verbatim": "This example shows findings from an assessment of microsatellite instability for genetic subregions that are known to be unstable. DNA extracted from tumor tissue is amplified and the resulting amplicons are resolved using wet laboratory methodology capillary electrophoresis.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+inline-R10-R15+O-P1-26+NEW1-NEW8", "ts": "2026-04-26T00:00:00Z"}}
