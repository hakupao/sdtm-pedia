{"atom_id": "ig34_p0179_a0012", "source": "SDTMIG_v3.4", "page": 179, "page_region": "middle", "parent_section": "§6.2.7 Protocol Deviations (DV)", "atom_type": "SENTENCE", "verbatim": "This is an example of data that was collected on a protocol-deviations CRF. The DVDECOD column is for controlled terminology, whereas the DVTERM is free text.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7_batch18", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0179_a0013", "source": "SDTMIG_v3.4", "page": 179, "page_region": "middle", "parent_section": "§6.2.7 Protocol Deviations (DV)", "atom_type": "LIST_ITEM", "verbatim": "Rows 1, 3:\tShow examples of a TREATMENT DEVIATION type of protocol deviation.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7_batch18", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0179_a0014", "source": "SDTMIG_v3.4", "page": 179, "page_region": "middle", "parent_section": "§6.2.7 Protocol Deviations (DV)", "atom_type": "LIST_ITEM", "verbatim": "Row 2:\tShows an example of a deviation due to the subject taking a prohibited concomitant medication.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7_batch18", "ts": "2026-04-25T00:00:00Z"}}
