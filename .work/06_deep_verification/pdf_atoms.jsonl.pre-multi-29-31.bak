{"atom_id": "ig34_p0111_a013", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 111, "atom_index_on_page": 13, "atom_type": "SENTENCE", "verbatim": "Upon unmasking, it became known that subject ABC1001 received drug X and Subject ABC2001 received drug Z. The EC dataset shows the administrations of study treatment as collected.", "parent_section": "§6.1.3.3 [Exposure/Exposure as Collected Examples]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": null, "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R14"}
