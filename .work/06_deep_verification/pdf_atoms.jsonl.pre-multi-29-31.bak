{"atom_id": "ig34_p0047_a017", "source": "SDTMIG_v3.4", "page": 47, "page_region": "middle", "parent_section": "§4.4.10 [Representing Time Points]", "atom_type": "TABLE_ROW", "verbatim": "PERIOD 1 | 3 | 1H | 2 | DAY 1, AM DOSE", "heading_level": null, "sibling_index": 2, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch05_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
