{"atom_id": "ig34_p0107_a009", "source": "SDTMIG_v3.4", "page": 107, "page_region": "middle", "parent_section": "§6.1.3.2 [Exposure as Collected (EC)]", "atom_type": "HEADING", "verbatim": "EC – Description/Overview", "heading_level": 5, "sibling_index": 1, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0107_a010", "source": "SDTMIG_v3.4", "page": 107, "page_region": "middle", "parent_section": "§6.1.3.2 [Exposure as Collected (EC)]", "atom_type": "SENTENCE", "verbatim": "An interventions domain that contains information about protocol-specified study treatment administrations, as collected.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10", "ts": "2026-04-25T00:00:00Z"}}
