{"atom_id": "ig34_p0225_a019", "source": "SDTMIG_v3.4", "page": 225, "page_region": "bottom", "parent_section": "§6.3.5.4 Genomics Findings (GF)", "atom_type": "SENTENCE", "verbatim": "This example shows transcription levels of genes ACTB and GAPDH and summarized scores from the transcription levels. Transcription levels and scores were determined using biocomputational analysis with wet laboratory methodology targeted transcriptome sequencing. Specific formulas used in biocomputational analyses to generate normalized and summarized score results are rerspresented when applicable.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+inline-R10-R15+O-P1-26+NEW1-NEW8", "ts": "2026-04-26T00:00:00Z"}}
{"atom_id": "ig34_p0226_a001", "source": "SDTMIG_v3.4", "page": 226, "page_region": "top", "parent_section": "§6.3.5.4 Genomics Findings (GF)", "atom_type": "LIST_ITEM", "verbatim": "Rows 1, 7:\tShow the number of fragments counted corresponding to the indicated gene.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+inline-R10-R15+O-P1-26+NEW1-NEW8", "ts": "2026-04-26T00:00:00Z"}}
