{"atom_id": "ig34_p0038_a030", "source": "SDTMIG_v3.4", "page": 38, "page_region": "bottom", "parent_section": "§4.4.1 Formats for Date/Time Variables", "atom_type": "LIST_ITEM", "verbatim": "[YYYY] = four-digit year", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0038_a031", "source": "SDTMIG_v3.4", "page": 38, "page_region": "bottom", "parent_section": "§4.4.1 Formats for Date/Time Variables", "atom_type": "LIST_ITEM", "verbatim": "[MM] = two-digit representation of the month (01-12, 01=January, etc.)", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0038_a032", "source": "SDTMIG_v3.4", "page": 38, "page_region": "bottom", "parent_section": "§4.4.1 Formats for Date/Time Variables", "atom_type": "LIST_ITEM", "verbatim": "[DD] = two-digit day of the month (01 through 31)", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
{"atom_id": "ig34_p0038_a033", "source": "SDTMIG_v3.4", "page": 38, "page_region": "bottom", "parent_section": "§4.4.1 Formats for Date/Time Variables", "atom_type": "LIST_ITEM", "verbatim": "[T] = (time designator) indicates time information follows", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
