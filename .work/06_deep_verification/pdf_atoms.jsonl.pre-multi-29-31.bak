{"atom_id": "ig34_p0102_a020", "source": "SDTMIG_v3.4", "page": 102, "page_region": "middle", "parent_section": "§6.1.2 [Concomitant/Prior Medications (CM)]", "atom_type": "LIST_ITEM", "verbatim": "Row 3: Medication use was solicited, but data were not collected. The reason for the lack of a response was collected and is represented in CMREASND.", "heading_level": null, "sibling_index": 3, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R10", "ts": "2026-04-25T00:00:00Z"}}
