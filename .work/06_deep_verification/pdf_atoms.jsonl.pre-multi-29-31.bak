{"atom_id": "ig34_p0160_a0015", "source": "SDTMIG_v3.4", "page": 160, "page_region": "top", "parent_section": "§6.2.4 Disposition (DS)", "atom_type": "SENTENCE", "verbatim": "The date of the unblinding is represented in DSSTDTC.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-5", "ts": "2026-04-25T19:00:00Z"}}
{"atom_id": "ig34_p0160_a0016", "source": "SDTMIG_v3.4", "page": 160, "page_region": "top", "parent_section": "§6.2.4 Disposition (DS)", "atom_type": "SENTENCE", "verbatim": "Maintaining the blind as per protocol was not considered to be an \"event\" because there was no change in the subject's state.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-5", "ts": "2026-04-25T19:00:00Z"}}
