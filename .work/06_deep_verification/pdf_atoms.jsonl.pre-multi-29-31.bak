{"atom_id": "ig34_p0087_a006", "source": "SDTMIG_v3.4", "page": 87, "page_region": "top", "parent_section": "§5.5 [Subject Visits (SV)]", "atom_type": "TABLE_ROW", "verbatim": "SVSTDY | Study Day of Start of Observation | Num | | Timing | Actual study day of start of observation expressed in integer days relative to the sponsor-defined RFSTDTC in Demographics. | Perm", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor", "ts": "2026-04-25T00:00:00Z"}}
