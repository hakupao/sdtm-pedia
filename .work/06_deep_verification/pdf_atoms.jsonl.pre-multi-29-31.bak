{"atom_id": "ig34_p0054_a021", "source": "SDTMIG_v3.4", "page": 54, "page_region": "middle", "parent_section": "§4.5.2 [Linking Multiple Observations]", "atom_type": "CROSS_REF", "verbatim": "See Section 8, Representing Relationships and Data, for guidance on expressing relationships among multiple observations.", "heading_level": null, "sibling_index": 1, "figure_ref": null, "cross_refs": ["§8"], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch06a_fix", "ts": "2026-04-25T00:00:00Z"}}
