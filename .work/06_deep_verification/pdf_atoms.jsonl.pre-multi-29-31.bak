{"atom_id": "ig34_p0039_a037", "source": "SDTMIG_v3.4", "page": 39, "page_region": "bottom", "parent_section": "§4.4.2 Date/Time Precision", "atom_type": "SENTENCE", "verbatim": "This date and date/time model also provides for imprecise or estimated dates, such as those commonly seen in Medical History.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
