{"atom_id":"ig34_p0269_a019","source":"SDTMIG_v3.4","page":269,"page_region":"middle","parent_section":"§6.3.5.9.1 Pharmacokinetics Concentrations (PC)","atom_type":"LIST_ITEM","verbatim":"1.\tThis domain can be used to represent specimen properties (e.g., volume, pH) in addition to drug and metabolite concentration measurements.","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2_round5_inline","ts":"2026-04-27T00:00:03Z"}}
