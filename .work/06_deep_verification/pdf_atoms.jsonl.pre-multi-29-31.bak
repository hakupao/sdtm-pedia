{"atom_id": "ig34_p0040_a009", "source": "SDTMIG_v3.4", "page": 40, "page_region": "top", "parent_section": "§4.4.2 Date/Time Precision", "atom_type": "SENTENCE", "verbatim": "When components are omitted, the expected delimiters must still be kept in place and only a single hyphen is to be used to indicate an omitted component.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
