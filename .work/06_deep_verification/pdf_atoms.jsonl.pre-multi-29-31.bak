{"atom_id": "ig34_p0033_a010", "source": "SDTMIG_v3.4", "page": 33, "page_region": "middle", "parent_section": "§4.2.7.2 \"Specify\" Values for Result Qualifier Variables", "atom_type": "LIST_ITEM", "verbatim": "If the sponsor wishes to maintain controlled terminology in the standard result field, but will expand the terminology based on values seen in the \"Other, specify\" field, then the free text is placed in --ORRES and the value of --STRESC will reflect the sponsor's coding decision.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+batch04_4digit_fix", "ts": "2026-04-25T00:00:00Z"}}
