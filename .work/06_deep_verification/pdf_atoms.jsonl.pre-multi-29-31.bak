{"atom_id": "ig34_p0090_a004", "source": "SDTMIG_v3.4", "page": 90, "page_region": "top", "parent_section": "§5.5 [Subject Visits (SV)]", "atom_type": "SENTENCE", "verbatim": "As originally planned, visits were to be conducted in person, but epidemic disruption necessitated conducting some visits remotely.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor", "ts": "2026-04-25T00:00:00Z"}}
