{"atom_id": "ig34_p0063_a023", "source": "SDTMIG_v3.4", "page": 63, "page_region": "middle", "parent_section": "§5.2 [Demographics (DM)]", "atom_type": "TABLE_ROW", "verbatim": "ETHNIC | Ethnicity | Char | (ETHNIC) | Record Qualifier | The ethnicity of the subject. Sponsors should refer to the FDA guidance1 regarding the collection of ethnicity. | Perm", "heading_level": null, "sibling_index": 23, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.2+batch07a_fix", "ts": "2026-04-25T00:00:00Z"}}
