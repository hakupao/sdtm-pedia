{"atom_id":"ig34_p0243_a013","source":"SDTMIG_v3.4","page":243,"page_region":"middle","parent_section":"§6.3.5.6 Laboratory Test Results (LB)","atom_type":"TABLE_ROW","verbatim":"| LBREASND | Reason Test Not Done | Char | | Record Qualifier | Describes why a measurement or test was not performed. Examples: \"BROKEN EQUIPMENT\", \"SUBJECT REFUSED\", or \"SPECIMEN LOST\". Used in conjunction with LBSTAT when value is \"NOT DONE\". | Perm |","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2","ts":"2026-04-26T00:00:00Z"}}
