{"atom_id":"ig34_p0181_a004","source":"SDTMIG_v3.4","page":181,"page_region":"top","parent_section":"§6.3.1 Product Accountability (DA)","atom_type":"TABLE_ROW","verbatim":"| DASTAT | Completion Status | Char | (ND) | Record Qualifier | Used to indicate that a product accountability assessment was not done. Should be null or have a value of \"NOT DONE\". | Perm |","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":["(ND)"],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2_inline_R10-15_O26_NEW1-7","ts":"2026-04-26T00:00:00Z"}}
