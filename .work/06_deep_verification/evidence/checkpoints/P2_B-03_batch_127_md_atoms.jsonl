{"atom_id": "md_dmTE_ex_a046", "file": "knowledge_base/domains/TE/examples.md", "line_start": 65, "line_end": 65, "parent_section": "§TE.4.2 [Distinguishing Elements, Study Cells, and Epochs]", "atom_type": "SENTENCE", "verbatim": "It is easy to confuse elements, which are reusable trial building blocks, with study cells (which contain the elements for a particular epoch and Arm) and with epochs (which are time periods for the trial as a whole).", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.3", "ts": "2026-05-07T18:00:00Z"}}
