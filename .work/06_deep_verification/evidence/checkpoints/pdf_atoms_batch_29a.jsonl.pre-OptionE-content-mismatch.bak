{"atom_id": "ig34_p0285_a030", "source": "SDTMIG_v3.4", "page": 285, "page_region": "bottom", "parent_section": "\u00a76.3.7.1 Generic Morphology/Physiology Specification", "atom_type": "LIST_ITEM", "verbatim": "The variables included in the generic morphology/physiology domain specification table are those required or expected in individual body-system-based morphology/physiology domains.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T01:49:12.330710Z"}}
