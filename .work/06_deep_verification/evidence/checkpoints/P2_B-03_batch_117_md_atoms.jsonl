{"atom_id": "md_dmSUPPQUAL_ex_a004", "file": "knowledge_base/domains/SUPPQUAL/examples.md", "line_start": 7, "line_end": 7, "parent_section": "§SUPPQUAL.1 [Example 1]", "atom_type": "SENTENCE", "verbatim": "The 2 rows of suppae.xpt add qualifying information to adverse event data (RDOMAIN = \"AE\"). IDVAR defines the key variable used to link this information to the AE data (AESEQ). IDVARVAL specifies the value of the key variable within the parent AE record to which the SUPPAE record applies. The remaining columns specify the supplemental variables' names (AEOSP and AETRTEM), labels, values, origin, and who made the evaluation.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.3", "ts": "2026-05-07T13:15:00Z"}}
{"atom_id": "md_dmSUPPQUAL_ex_a005", "file": "knowledge_base/domains/SUPPQUAL/examples.md", "line_start": 9, "line_end": 9, "parent_section": "§SUPPQUAL.1 [Example 1]", "atom_type": "SENTENCE", "verbatim": "**suppae.xpt**", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.3", "ts": "2026-05-07T13:15:00Z"}}
