{"atom_id":"ig34_p0265_a016","source":"SDTMIG_v3.4","page":265,"page_region":"middle","parent_section":"§6.3.5.8 Microscopic Findings (MI)","atom_type":"TABLE_ROW","verbatim":"MIDY | Study Day of Specimen Collection | Num | | Timing | Study day of specimen collection, in integer days. The algorithm for calculations must be relative to the sponsor-defined RFSTDTC variable in the Demographics (DM) domain. | Perm","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"oh-my-claudecode:executor","prompt_version":"P0_writer_pdf_v1.2_round5_inline","ts":"2026-04-27T00:04:00Z"}}
