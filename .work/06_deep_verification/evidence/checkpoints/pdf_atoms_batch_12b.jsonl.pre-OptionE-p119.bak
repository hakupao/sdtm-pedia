{"atom_id": "ig34_p0120_a006", "source": "SDTMIG v3.4 (no header footer).pdf", "source_short": "ig34", "page": 120, "atom_index_on_page": 6, "atom_type": "SENTENCE", "verbatim": "The EX dataset shows the unmasked treatment for this subject, \"DRUG X\", and represents dosing in nonoverlapping intervals of time.", "parent_section": "§6.1.3.3 [Exposure/Exposure as Collected Examples]", "heading_level": null, "sibling_index": null, "cross_refs": null, "figure_ref": null, "table_ref": null, "prompt_version": "P0_writer_pdf_v1.2+TOC_anchor+R1-R14"}
