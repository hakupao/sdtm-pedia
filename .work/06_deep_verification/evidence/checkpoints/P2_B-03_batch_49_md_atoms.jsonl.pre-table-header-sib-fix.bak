{"atom_id": "md_dmFA_ex_a060", "atom_type": "SENTENCE", "file": "knowledge_base/domains/FA/examples.md", "line_start": 90, "line_end": 90, "verbatim": "The FA records were linked to the parent CE record via the AE reference number, which was used to populate both AESPID and FASPID.", "parent_section": "§FA.2 [Example 2]", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.1", "ts": "2026-05-06T08:00:00Z"}}
