{"atom_id": "ig34_p0376_a009", "source": "SDTMIG_v3.4", "page": 376, "page_region": "top", "parent_section": "SR – Specification", "atom_type": "TABLE_ROW", "verbatim": "| SRGRPID | Group ID | Char | | Identifier | Used to tie together a block of related records in a single domain for a subject. | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.5", "ts": "2026-04-28T00:00:00Z"}}
{"atom_id": "ig34_p0376_a010", "source": "SDTMIG_v3.4", "page": 376, "page_region": "top", "parent_section": "SR – Specification", "atom_type": "TABLE_ROW", "verbatim": "| SREFID | Reference ID | Char | | Identifier | Internal or external specimen identifier. Example: \"Specimen ID\". | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:executor", "prompt_version": "P0_writer_pdf_v1.5", "ts": "2026-04-28T00:00:00Z"}}
