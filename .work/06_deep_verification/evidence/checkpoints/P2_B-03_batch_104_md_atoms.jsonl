{"atom_id":"md_dmRELSPEC_assn_a004","file":"knowledge_base/domains/RELSPEC/assumptions.md","line_start":7,"line_end":7,"parent_section":"§RELSPEC [RELSPEC — Assumptions]","atom_type":"LIST_ITEM","verbatim":"1. The RELSPEC dataset is not used to manage relationships between any other datasets or domains.","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"general-purpose","prompt_version":"P0_writer_md_v1.9.3","ts":"2026-05-07T11:50:00Z"}}
{"atom_id":"md_dmRELSPEC_assn_a005","file":"knowledge_base/domains/RELSPEC/assumptions.md","line_start":9,"line_end":9,"parent_section":"§RELSPEC [RELSPEC — Assumptions]","atom_type":"LIST_ITEM","verbatim":"2. The RELSPEC dataset is only used to maintain relationships between specimens, therefore it does not require any additional variables such as those used in RELREC.","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":["RELREC"],"extracted_by":{"subagent_type":"general-purpose","prompt_version":"P0_writer_md_v1.9.3","ts":"2026-05-07T11:50:00Z"}}
