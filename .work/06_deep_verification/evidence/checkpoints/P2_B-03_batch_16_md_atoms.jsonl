{"atom_id": "md_dmAG_ex_a003", "atom_type": "SENTENCE", "file": "knowledge_base/domains/AG/examples.md", "line_start": 5, "line_end": 5, "verbatim": "This example captures data about the allergen administered to the subject as part of a bronchial allergen challenge (BAC) test.", "parent_section": "§AG.1 [Example 1]", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.1", "ts": "2026-05-05T22:30:00Z"}}
