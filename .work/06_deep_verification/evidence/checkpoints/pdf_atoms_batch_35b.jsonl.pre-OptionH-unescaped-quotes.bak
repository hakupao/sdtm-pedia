{"atom_id": "ig34_p0348_a015", "source": "SDTMIG_v3.4", "page": 348, "page_region": "bottom", "parent_section": "TU – Assumptions", "atom_type": "SENTENCE", "verbatim": "This example shows indicator TUTESTS for the identification of the sites of metastatic disease sites at baseline.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.4", "ts": "2026-04-28T00:00:00Z"}}
