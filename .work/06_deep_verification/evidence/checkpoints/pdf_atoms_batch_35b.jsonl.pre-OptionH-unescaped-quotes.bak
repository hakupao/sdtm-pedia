{"atom_id": "ig34_p0350_a003", "source": "SDTMIG_v3.4", "page": 350, "page_region": "top", "parent_section": "TR – Description/Overview", "atom_type": "SENTENCE", "verbatim": "A findings domain that represents quantitative measurements and/or qualitative assessments of the tumors, lesions, or locations of interest identified in the Tumor/Lesion Identification (TU) domain.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.4", "ts": "2026-04-28T00:00:00Z"}}
