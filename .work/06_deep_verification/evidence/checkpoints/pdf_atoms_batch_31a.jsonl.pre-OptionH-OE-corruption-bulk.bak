{"atom_id": "ig34_p0302_a006", "source": "SDTMIG_v3.4", "page": 302, "page_region": "top", "parent_section": "§6.3.7.5 Ophthalmic Examinations (OE)", "atom_type": "SENTENCE", "verbatim": "The supplemental qualifier dataset represents the multiple directionality values, further describing the anatomical location where the abnormality was observed.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T00:00:00Z"}}
