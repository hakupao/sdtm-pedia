{"atom_id": "ig34_p0301_a007", "source": "SDTMIG_v3.4", "page": 301, "page_region": "top", "parent_section": "§6.3.7.5 Ophthalmic Examinations (OE)", "atom_type": "TABLE_ROW", "verbatim": "| OEELTM | Planned Elapsed Time from Time Point Ref | Char | ISO 8601 duration | Timing | Planned Elapsed time relative to a planned time point reference (OETPREF; e.g., \"PREVIOUS DOSE\", \"PREVIOUS MEAL\"). This variable is useful where there are repetitive measures. Not a clock time or a lifetime variable, but an interval within a specified period, e.g., within 30 days of a test. | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T00:00:00Z"}}
{"atom_id": "ig34_p0301_a008", "source": "SDTMIG_v3.4", "page": 301, "page_region": "top", "parent_section": "§6.3.7.5 Ophthalmic Examinations (OE)", "atom_type": "TABLE_ROW", "verbatim": "| OETPREF | Time Point Reference | Char | ISO 8601 datetime | Timing | Description of the time reference point referred to by OETPT, OETPTNUM, and OEELTM. | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T00:00:00Z"}}
