{"atom_id": "ig34_p0305_a029", "source": "SDTMIG_v3.4", "page": 305, "page_region": "bottom", "parent_section": "§6.3.7.6 Reproductive System Findings (RP)", "atom_type": "TABLE_ROW", "verbatim": "| RPCAT | Category for Reproductive Test | Char | | Grouping Qualifier | Used to define a category of topic-variable values. Example: \"No use case to date, but values would be relative to reproduction tests grouping\". | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T00:00:00Z"}}
{"atom_id": "ig34_p0305_a030", "source": "SDTMIG_v3.4", "page": 305, "page_region": "bottom", "parent_section": "§6.3.7.6 Reproductive System Findings (RP)", "atom_type": "TABLE_ROW", "verbatim": "| RPSCAT | Subcategory for Reproductive Test | Char | | Grouping Qualifier | Used to define a further categorization of RPCAT values. Example: \"No use case to date, but values would be relative to reproduction tests grouping\". | Perm |", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "oh-my-claudecode:writer", "prompt_version": "P0_writer_pdf_v1.3", "ts": "2026-04-27T00:00:00Z"}}
