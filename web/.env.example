# Public env vars (Astro PUBLIC_* prefix → exposed to client bundle).
# Copy to web/.env to override locally. CI/CF Pages should set these in
# the deploy environment, not by committing .env.

# Toggle the DownloadsSection bundle grid on/off. Set to "true" only after
# the v1.0 GitHub release with 4 zip artifacts is published; otherwise the
# 4 download links 404. Default off (placeholder pending message shown).
PUBLIC_RELEASE_PUBLISHED=false
