# Public env vars (Astro PUBLIC_* prefix → exposed to client bundle).
# Copy to web/.env to override locally. CI/CF Pages should set these in
# the deploy environment, not by committing .env.

# Toggle the DownloadsSection bundle grid on/off. Defaults to "published" in
# code so a fresh clone shows the live download grid. Set to "false" only
# during a release-prep window (downloads.json bumped to a new tag that has
# not yet been pushed to GitHub releases) or when testing the placeholder.
PUBLIC_RELEASE_PUBLISHED=true
