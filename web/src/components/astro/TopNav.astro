---
import { ThemeToggle } from '../react/ThemeToggle';
import { FontSizeToggle } from '../react/FontSizeToggle';
import { LangSwitcher } from '../react/LangSwitcher';
import { SearchOverlay } from '../react/SearchOverlay';
import { getUIStrings, type Lang } from '../../i18n/helpers';
interface Props { lang: Lang; pathname: string; }
const { lang, pathname } = Astro.props;
const t = getUIStrings(lang);
---
<header class="border-b border-rule">
  <div class="max-w-screen-xl mx-auto px-7 h-14 flex justify-between items-center">
    <div class="font-mono text-[10px] tracking-[0.18em] text-ink font-bold whitespace-nowrap">
      SDTM/KB · VOL.01 · 2026
    </div>
    <button id="mobile-nav-toggle" class="md:hidden font-mono text-base px-2" aria-label="Open menu">☰</button>
    <nav id="mobile-nav-content" class="hidden md:flex items-center font-mono text-xs tracking-wider text-ink-mute">
      <div class="flex items-center gap-5">
        <a href={`/${lang}/guide/user-guide/`} class="hover:text-accent">{t['nav.guide']}</a>
        <a href={`/${lang}/#platforms`} class="hover:text-accent">{t['nav.platforms']}</a>
        <a href={`/${lang}/guide/demo-questions`} class="hover:text-accent">{t['nav.demo']}</a>
        <a href={`/${lang}/#downloads`} class="hover:text-accent">{t['nav.download']}</a>
      </div>
      <div class="flex items-center ml-5 divide-x divide-rule">
        <button
          type="button"
          class="px-4 hover:text-accent"
          onclick="document.dispatchEvent(new KeyboardEvent('keydown', {key:'k', metaKey:true}))"
          aria-label={t['search.label']}
        >
          {t['search.label']}
        </button>
        <span class="px-4 flex items-center">
          <LangSwitcher client:load currentLang={lang} pathname={pathname} />
        </span>
        <span class="px-4 flex items-center">
          <ThemeToggle
            client:load
            navLabel={t['theme.label']}
            labels={{
              light: t['theme.light'],
              dark: t['theme.dark'],
              system: t['theme.system'],
            }}
          />
        </span>
        <span class="pl-4 flex items-center">
          <FontSizeToggle
            client:load
            navLabel={t['fontsize.label']}
            labels={{
              sm: t['fontsize.sm'],
              md: t['fontsize.md'],
              lg: t['fontsize.lg'],
              xl: t['fontsize.xl'],
            }}
          />
        </span>
      </div>
    </nav>
  </div>
</header>
<SearchOverlay client:load lang={lang} />
<script>
  const btn = document.getElementById('mobile-nav-toggle');
  const nav = document.getElementById('mobile-nav-content');
  btn?.addEventListener('click', () => {
    nav?.classList.toggle('hidden');
  });
</script>
