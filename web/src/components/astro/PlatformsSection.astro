---
import SectionLabel from './SectionLabel.astro';
import platforms from '../../data/platforms.json';
import { getUIStrings, type Lang } from '../../i18n/helpers';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getUIStrings(lang);
const subhead = t['section.platforms.subhead'];
---
<section id="platforms" class="enter-fade py-8 bg-bg-alt border-b border-rule">
  <div class="max-w-screen-xl mx-auto px-5 md:px-7">
    <SectionLabel number="02" label={t['section.platforms.label']} />
    <h2 class="font-display text-2xl mb-5 leading-tight">{subhead}</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
      {platforms.map((p) => (
        <a
          href={`/${lang}/deploy/${p.key}/`}
          class="bg-bg p-4 border border-rule hover:border-accent transition-colors group flex flex-col"
        >
          <div class="font-mono text-[8px] tracking-[0.15em] text-ink-mute">{p.name}</div>
          <div class="font-serif text-[13px] text-ink leading-snug mt-3 min-h-[2.5rem]">{p.strength[lang]}</div>
          <div class="mt-2 font-mono text-[9px] tracking-wider text-ink-mute group-hover:text-accent">
            {t['nav.deploy']} →
          </div>
        </a>
      ))}
    </div>
    <a href={`/${lang}/deploy/chatgpt/`} class="inline-block mt-4 font-mono text-[9px] tracking-wider text-ink-mute hover:text-accent">
      {t['section.platforms.cta']}
    </a>
  </div>
</section>
