---
import { getUIStrings, type Lang } from '../../i18n/helpers';
import platforms from '../../data/platforms.json';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = getUIStrings(lang);
const statusLine = platforms.map((p) => `${p.name} ${p.scoreText}/17`).join(' · ');
const headline = {
  zh: { main: 'SDTM 知识库,', em: '横跨四个', tail: 'AI 平台.' },
  en: { main: 'SDTM knowledge,', em: 'across four', tail: 'AI platforms.' },
  ja: { main: 'SDTM ナレッジを、', em: '4 つの', tail: 'AI プラットフォームへ。' },
}[lang];
const subdeck = {
  zh: '完整整理的 CDISC SDTMIG v3.4 参考库 — 完成映射、部署与评估. 每题 1 分钟, 一个带引用的回答.',
  en: 'A curated reference set for CDISC SDTMIG v3.4 — mapped, deployed, and evaluated. One question, one minute, one cited answer.',
  ja: 'CDISC SDTMIG v3.4 の体系的リファレンス — マッピング・デプロイメント・評価まで完了。1 問、1 分、引用付きの回答 1 つ。',
}[lang];
---
<section class="enter-fade pt-14 pb-8 border-b border-rule">
  <div class="max-w-screen-xl mx-auto px-5 md:px-7">
    <div class="font-mono text-[10px] tracking-[0.2em] text-accent font-bold mb-6">
      — 04 INTERNAL RELEASE
    </div>
    <h1 class="font-display text-4xl md:text-6xl font-bold leading-[1.05] tracking-[-0.025em] mb-4">
      {headline.main}<br />
      <em class="not-italic font-bold text-accent">{headline.em}</em> {headline.tail}
    </h1>
    <p class="font-serif text-[15px] leading-[1.55] text-ink-mute max-w-[480px] mt-5">{subdeck}</p>
    <div class="flex gap-2 mt-8 items-center flex-wrap">
      <a href={`/${lang}/guide/user-guide/`} class="bg-ink text-bg px-4 py-2 font-mono text-[11px] tracking-wider font-bold hover:bg-accent transition-colors">
        {t['hero.cta.read']}
      </a>
      <a href="#downloads" class="border border-ink px-4 py-2 font-mono text-[11px] tracking-wider font-bold hover:border-accent hover:text-accent transition-colors">
        {t['hero.cta.download']}
      </a>
      <a href="https://github.com/hakupao/sdtm-pedia" class="px-3 py-2 font-mono text-[11px] tracking-wider text-ink-mute hover:text-accent transition-colors">
        {t['hero.cta.github']}
      </a>
    </div>
    <div class="mt-4 font-mono text-[9px] tracking-wider text-ink-mute">
      <span class="text-accent">●</span>  LIVE · {statusLine}
    </div>
  </div>
</section>
