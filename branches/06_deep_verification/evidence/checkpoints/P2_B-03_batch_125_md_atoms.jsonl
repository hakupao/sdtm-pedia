{"atom_id": "md_dmTA_ex_a220", "file": "knowledge_base/domains/TA/examples.md", "line_start": 608, "line_end": 608, "parent_section": "§TA.7 [Example 7]", "atom_type": "SENTENCE", "verbatim": "This is a complex 2-arm trial (CR = Chemotherapy and Radiation; CRS = Chemotherapy, Radiation, and Surgery) with 4 epochs (Screening, Induction Treatment, Continuation Treatment, Follow-up) and major \"skip forward\" arrows for disease progression.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "general-purpose", "prompt_version": "P0_writer_md_v1.9.3", "ts": "2026-05-07T17:00:00Z"}}
