{"atom_id": "md_dmTV_ex_a046", "file": "knowledge_base/domains/TV/examples.md", "line_start": 80, "line_end": 80, "parent_section": "§TV.2.4 [Contingent Visits]", "atom_type": "SENTENCE", "verbatim": "When such planned data collection involves an additional clinic visit, a \"contingent\" visit may be included in the TV table, with a rule that describes the circumstances under which it will take place.", "heading_level": null, "sibling_index": null, "figure_ref": null, "cross_refs": [], "extracted_by": {"subagent_type": "executor", "prompt_version": "P0_writer_md_v1.9.4", "ts": "2026-05-11T08:00:00Z"}}
