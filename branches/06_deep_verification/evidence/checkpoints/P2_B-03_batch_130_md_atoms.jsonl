{"atom_id":"md_dmTM_assn_a002","file":"knowledge_base/domains/TM/assumptions.md","line_start":3,"line_end":3,"parent_section":"§TM [TM — Assumptions]","atom_type":"SENTENCE","verbatim":"A trial design domain that is used to describe disease milestones, which are observations or activities anticipated to occur in the course of the disease under study, and which trigger the collection of data.","heading_level":null,"sibling_index":null,"figure_ref":null,"cross_refs":[],"extracted_by":{"subagent_type":"general-purpose","prompt_version":"P0_writer_md_v1.9.3","ts":"2026-05-07T12:46:45Z"}}
